---
import { getAllCategories, getAllLanguages } from '../../lib/data/collections';

const categories = await getAllCategories();
const languages = await getAllLanguages();
const topCategories = categories.slice(0, 6);
const topLanguages = languages.slice(0, 6);
---

<footer class="bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center text-white font-bold text-sm">
            BY
          </div>
          <span class="font-bold text-lg">Build Your Own X</span>
        </a>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
          Master programming by recreating your favorite technologies from scratch.
        </p>
        <div class="flex items-center gap-4">
          <a 
            href="https://github.com/codecrafters-io/build-your-own-x"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Categories -->
      <div>
        <h3 class="font-semibold text-sm mb-4">Categories</h3>
        <ul class="space-y-2">
          {topCategories.map(cat => (
            <li>
              <a 
                href={`${import.meta.env.BASE_URL}category/${cat.slug}`}
                class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              >
                {cat.name}
              </a>
            </li>
          ))}
          <li>
            <a 
              href={`${import.meta.env.BASE_URL}category`}
              class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
            >
              View All →
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Languages -->
      <div>
        <h3 class="font-semibold text-sm mb-4">Languages</h3>
        <ul class="space-y-2">
          {topLanguages.map(lang => (
            <li>
              <a 
                href={`${import.meta.env.BASE_URL}language/${lang.slug}`}
                class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
              >
                {lang.name}
              </a>
            </li>
          ))}
          <li>
            <a 
              href={`${import.meta.env.BASE_URL}search`}
              class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
            >
              Browse All →
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Links -->
      <div>
        <h3 class="font-semibold text-sm mb-4">Resources</h3>
        <ul class="space-y-2">
          <li>
            <a 
              href={`${import.meta.env.BASE_URL}contribute`}
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              Contribute
            </a>
          </li>
          <li>
            <a 
              href="https://github.com/codecrafters-io/build-your-own-x/blob/master/README.md"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              Original README
            </a>
          </li>
          <li>
            <a 
              href="https://codecrafters.io"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
            >
              CodeCrafters
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="border-t border-gray-200 dark:border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        © {new Date().getFullYear()} Build Your Own X. Licensed under MIT.
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Created by <a href="https://github.com/danistefanovic" class="hover:text-primary-600 dark:hover:text-primary-400">Daniel Stefanovic</a> · Maintained by <a href="https://codecrafters.io" class="hover:text-primary-600 dark:hover:text-primary-400">CodeCrafters</a>
      </p>
    </div>
  </div>
</footer>
