---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/navigation/Header.astro';
import Footer from '../../components/navigation/Footer.astro';
import { getAllLanguages } from '../../lib/data/collections';

const languages = await getAllLanguages();
---

<BaseLayout
  title="Languages - Build Your Own X"
  description={`Browse all ${languages.length} programming languages with tutorials. Find tutorials in Python, JavaScript, C, Rust, Go, and more.`}
>
  <Header />

  <main class="flex-grow">
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary-50 to-white dark:from-gray-900 dark:to-gray-900/50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Browse by Language
          </h1>
          <p class="text-gray-600 dark:text-gray-400">
            Explore {languages.length} programming languages with hands-on tutorials.
            Pick your language and start building real projects from scratch.
          </p>
        </div>
      </div>
    </section>

    <!-- Languages Grid -->
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {languages.map(lang => (
            <a
              href={`${import.meta.env.BASE_URL}language/${lang.slug}`}
              class="group block bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200"
            >
              <div class="flex items-center gap-3 mb-3">
                <span
                  class="w-4 h-4 rounded-full flex-shrink-0"
                  style={`background-color: ${lang.brandColor};`}
                ></span>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                  {lang.name}
                </h2>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
                {lang.tutorialCount} {lang.tutorialCount === 1 ? 'tutorial' : 'tutorials'}
              </p>
              <span class="text-sm font-medium text-primary-600 dark:text-primary-400 group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors">
                Explore tutorials &rarr;
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
