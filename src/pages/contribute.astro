---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
---

<BaseLayout 
  title="Contribute - Build Your Own X"
  description="Contribute to Build Your Own X. Submit tutorials that teach how to build technologies from scratch."
>
  <Header />
  
  <main class="flex-grow">
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary-50 to-white dark:from-gray-900 dark:to-gray-900/50 py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Contribute to Build Your Own X
        </h1>
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          Help others learn by sharing tutorials that teach how to build technologies from scratch.
        </p>
      </div>
    </section>
    
    <!-- Content -->
    <section class="py-12 lg:py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose dark:prose-invert max-w-none">
          <h2>How to Contribute</h2>
          <p>
            Build Your Own X is a community-driven project. We welcome contributions of tutorials 
            that teach how to build technologies from scratch.
          </p>
          
          <h3>What We're Looking For</h3>
          <ul>
            <li>Tutorials that teach how to build a specific technology from scratch</li>
            <li>Step-by-step guides with clear explanations</li>
            <li>Code examples in any programming language</li>
            <li>Projects that help developers understand how things work under the hood</li>
          </ul>
          
          <h3>How to Submit</h3>
          <ol>
            <li>
              <strong>Fork the repository</strong> on GitHub
            </li>
            <li>
              <strong>Add your tutorial</strong> to the appropriate category in the README.md
            </li>
            <li>
              <strong>Submit a pull request</strong> with a clear description
            </li>
          </ol>
          
          <div class="bg-primary-50 dark:bg-primary-900/20 rounded-lg p-6 my-8">
            <h3 class="mt-0">Ready to contribute?</h3>
            <p class="mb-4">
              Head over to GitHub to submit your tutorial.
            </p>
            <a 
              href="https://github.com/codecrafters-io/build-your-own-x"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
              Go to GitHub
            </a>
          </div>
          
          <h3>Submission Guidelines</h3>
          <ul>
            <li>Make sure the tutorial is freely accessible</li>
            <li>Include the programming language in the title</li>
            <li>Choose the most appropriate category</li>
            <li>Check that the link works</li>
            <li>Ensure the tutorial teaches concepts, not just copy-paste code</li>
          </ul>
          
          <h3>Code of Conduct</h3>
          <p>
            This project adheres to a code of conduct. By participating, you are expected to 
            uphold this code. Please be respectful and constructive in all interactions.
          </p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
