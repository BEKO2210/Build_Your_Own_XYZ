---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import TutorialCard from '../components/content/TutorialCard.astro';
import { getAllTutorials, getAllCategories, getAllLanguages } from '../lib/data/collections';

const tutorials = await getAllTutorials();
const categories = await getAllCategories();
const languages = await getAllLanguages();

// Get search query from URL
const query = Astro.url.searchParams.get('q') || '';
const categoryFilter = Astro.url.searchParams.get('category') || '';
const languageFilter = Astro.url.searchParams.get('language') || '';

// Filter tutorials
let filteredTutorials = tutorials;

if (query) {
  const lowerQuery = query.toLowerCase();
  filteredTutorials = filteredTutorials.filter(t => 
    t.title.toLowerCase().includes(lowerQuery) ||
    t.category.toLowerCase().includes(lowerQuery) ||
    t.languages.some(l => l.toLowerCase().includes(lowerQuery))
  );
}

if (categoryFilter) {
  filteredTutorials = filteredTutorials.filter(t => t.categorySlug === categoryFilter);
}

if (languageFilter) {
  filteredTutorials = filteredTutorials.filter(t => t.languageSlugs.includes(languageFilter));
}
---

<BaseLayout 
  title={query ? `Search: ${query} - Build Your Own X` : 'Search Tutorials - Build Your Own X'}
  description="Search 358+ tutorials for building your favorite technologies from scratch. Filter by category, language, and more."
>
  <Header />
  
  <main class="flex-grow">
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary-50 to-white dark:from-gray-900 dark:to-gray-900/50 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          Search Tutorials
        </h1>
        
        <!-- Search Form -->
        <form class="max-w-2xl" action={`${import.meta.env.BASE_URL}search`} method="get">
          <div class="relative">
            <input 
              type="text"
              name="q"
              value={query}
              placeholder="Search tutorials..."
              class="w-full px-4 py-3 pl-12 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent dark:text-white"
            />
            <svg 
              class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          
          <!-- Filters -->
          <div class="flex flex-wrap gap-4 mt-4">
            <select 
              name="category"
              class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white"
            >
              <option value="">All Categories</option>
              {categories.map(cat => (
                <option value={cat.slug} selected={cat.slug === categoryFilter}>{cat.name}</option>
              ))}
            </select>
            
            <select 
              name="language"
              class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white"
            >
              <option value="">All Languages</option>
              {languages.map(lang => (
                <option value={lang.slug} selected={lang.slug === languageFilter}>{lang.name}</option>
              ))}
            </select>
            
            <button 
              type="submit"
              class="px-6 py-2 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
            >
              Search
            </button>
            
            {(query || categoryFilter || languageFilter) && (
              <a 
                href={`${import.meta.env.BASE_URL}search`}
                class="px-4 py-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
              >
                Clear
              </a>
            )}
          </div>
        </form>
      </div>
    </section>
    
    <!-- Results -->
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {(query || categoryFilter || languageFilter) && (
          <div class="mb-6">
            <p class="text-gray-600 dark:text-gray-400">
              Found <span class="font-semibold text-gray-900 dark:text-white">{filteredTutorials.length}</span> tutorials
              {query && <span> for "<span class="font-semibold">{query}</span>"</span>}
            </p>
          </div>
        )}
        
        {filteredTutorials.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {filteredTutorials.map(tutorial => (
              <TutorialCard tutorial={tutorial} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <svg 
              class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-700 mb-4" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No tutorials found</h3>
            <p class="text-gray-500 dark:text-gray-400">Try adjusting your search or filters.</p>
          </div>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
