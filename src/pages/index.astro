---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import TutorialCard from '../components/content/TutorialCard.astro';
import CategoryCard from '../components/content/CategoryCard.astro';
import { getAllCategories, getAllTutorials, getAllLanguages } from '../lib/data/collections';

const categories = await getAllCategories();
const tutorials = await getAllTutorials();
const languages = await getAllLanguages();

const featuredCategories = categories.slice(0, 8);
const recentTutorials = tutorials.slice(-6).reverse();

const stats = [
  { value: tutorials.length.toString(), label: 'Tutorials' },
  { value: categories.length.toString(), label: 'Categories' },
  { value: languages.length.toString(), label: 'Languages' }
];
---

<BaseLayout 
  title="Build Your Own X - Master Technologies by Building Them"
  description={`Master programming by recreating your favorite technologies from scratch. ${tutorials.length}+ tutorials across ${categories.length}+ categories and ${languages.length}+ programming languages.`}
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-primary-100 dark:from-gray-900 dark:via-gray-900 dark:to-primary-900/20">
      <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 relative">
        <div class="text-center max-w-3xl mx-auto">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6 tracking-tight">
            Build Your Own <span class="text-primary-600 dark:text-primary-400">X</span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            Master programming by recreating your favorite technologies from scratch. 
            Step-by-step tutorials that teach you how things work under the hood.
          </p>
          
          <!-- Stats -->
          <div class="flex items-center justify-center gap-8 mb-10">
            {stats.map(stat => (
              <div class="text-center">
                <div class="text-2xl sm:text-3xl font-bold text-primary-600 dark:text-primary-400">{stat.value}</div>
                <div class="text-sm text-gray-500 dark:text-gray-400">{stat.label}</div>
              </div>
            ))}
          </div>
          
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a 
              href={`${import.meta.env.BASE_URL}search`}
              class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors shadow-lg shadow-primary-600/20"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Search Tutorials
            </a>
            <a 
              href={`${import.meta.env.BASE_URL}category`}
              class="inline-flex items-center px-6 py-3 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium rounded-lg border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
            >
              Browse Categories
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Featured Categories -->
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Browse by Category</h2>
            <p class="text-gray-600 dark:text-gray-400 mt-1">Explore tutorials organized by technology type</p>
          </div>
          <a 
            href={`${import.meta.env.BASE_URL}category`}
            class="hidden sm:inline-flex items-center text-primary-600 dark:text-primary-400 font-medium hover:underline"
          >
            View All
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredCategories.map(category => (
            <CategoryCard category={category} />
          ))}
        </div>
        
        <div class="mt-8 text-center sm:hidden">
          <a 
            href={`${import.meta.env.BASE_URL}category`}
            class="inline-flex items-center text-primary-600 dark:text-primary-400 font-medium"
          >
            View All Categories
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
    
    <!-- Recently Added -->
    <section class="py-16 lg:py-24 bg-gray-50 dark:bg-gray-800/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Recently Added</h2>
            <p class="text-gray-600 dark:text-gray-400 mt-1">Fresh tutorials from the community</p>
          </div>
          <a 
            href={`${import.meta.env.BASE_URL}search`}
            class="hidden sm:inline-flex items-center text-primary-600 dark:text-primary-400 font-medium hover:underline"
          >
            Browse All
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recentTutorials.map(tutorial => (
            <TutorialCard tutorial={tutorial} />
          ))}
        </div>
      </div>
    </section>
    
    <!-- About & Credits Section -->
    <section class="py-16 lg:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 dark:from-primary-900/20 dark:to-gray-800 rounded-2xl p-8 lg:p-12 text-center">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
            Wissen zugänglicher machen
          </h2>
          <p class="text-gray-600 dark:text-gray-300 mb-6 max-w-2xl mx-auto leading-relaxed">
            Diese Website wurde von <strong>Belkis Aslani</strong> erstellt, um die fantastische Sammlung
            des <a href="https://github.com/codecrafters-io/build-your-own-x" target="_blank" rel="noopener noreferrer" class="text-primary-600 dark:text-primary-400 hover:underline">Build Your Own X</a>-Repositories
            zugänglicher zu machen. Mein Ziel: Alle Tutorials übersichtlich aufbereitet, mit eingebetteten Videos,
            durchsuchbar und für jeden nutzbar - egal ob am Handy oder Desktop.
          </p>
          <p class="text-gray-500 dark:text-gray-400 mb-8 max-w-2xl mx-auto text-sm">
            Danke an <a href="https://github.com/danistefanovic" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400">Daniel Stefanovic</a>,
            <a href="https://codecrafters.io" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400">CodeCrafters</a>
            und die gesamte Community für das Original-Repository mit über 484.000 Stars.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href={`${import.meta.env.BASE_URL}contribute`}
              class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors"
            >
              Mitmachen
            </a>
            <a
              href={`${import.meta.env.BASE_URL}impressum`}
              class="inline-flex items-center px-6 py-3 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium rounded-lg border border-gray-300 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
            >
              Impressum
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
