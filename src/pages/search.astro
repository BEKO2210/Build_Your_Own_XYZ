---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import { getAllTutorials, getAllCategories, getAllLanguages } from '../lib/data/collections';

const tutorials = await getAllTutorials();
const categories = await getAllCategories();
const languages = await getAllLanguages();
---

<BaseLayout
  title="Search Tutorials - Build Your Own X"
  description="Search 358+ tutorials for building your favorite technologies from scratch. Filter by category, language, difficulty and content type."
>
  <Header />

  <main class="flex-grow">
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary-50 to-white dark:from-gray-900 dark:to-gray-900/50 py-10 sm:py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-6">
          Search Tutorials
        </h1>

        <!-- Search Input -->
        <div class="max-w-2xl">
          <div class="relative">
            <input
              type="text"
              id="search-input"
              placeholder="Search tutorials... (press / to focus)"
              autocomplete="off"
              class="w-full px-4 py-3.5 pl-12 pr-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-transparent dark:text-white text-base shadow-sm"
            />
            <svg
              class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"
              fill="none" stroke="currentColor" viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:inline-flex items-center px-2 py-0.5 text-xs text-gray-400 bg-gray-100 dark:bg-gray-700 rounded border border-gray-300 dark:border-gray-600 font-mono" id="slash-hint">/</kbd>
          </div>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 mt-5">
          <select id="filter-category" class="px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white shadow-sm">
            <option value="">All Categories</option>
            {categories.map(cat => (
              <option value={cat.slug}>{cat.name} ({cat.tutorialCount})</option>
            ))}
          </select>

          <select id="filter-language" class="px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white shadow-sm">
            <option value="">All Languages</option>
            {languages.map(lang => (
              <option value={lang.slug}>{lang.name} ({lang.tutorialCount})</option>
            ))}
          </select>

          <select id="filter-difficulty" class="px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white shadow-sm">
            <option value="">All Difficulties</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>

          <select id="filter-type" class="px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg text-sm dark:text-white shadow-sm">
            <option value="">All Types</option>
            <option value="article">Articles</option>
            <option value="video">Videos</option>
            <option value="repository">Repositories</option>
          </select>

          <button
            id="clear-filters"
            class="hidden px-4 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors font-medium"
          >
            Clear All
          </button>
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="py-8 sm:py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Result count -->
        <div class="mb-6 flex items-center justify-between">
          <p id="result-count" class="text-gray-600 dark:text-gray-400">
            Showing <span class="font-semibold text-gray-900 dark:text-white">{tutorials.length}</span> tutorials
          </p>
          <div class="flex items-center gap-2">
            <button id="view-grid" class="p-2 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400" aria-label="Grid view">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </button>
            <button id="view-list" class="p-2 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="List view">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Grid View -->
        <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No tutorials found</h3>
          <p class="text-gray-500 dark:text-gray-400">Try adjusting your search or filters.</p>
        </div>

        <!-- Load more -->
        <div id="load-more-wrap" class="mt-8 text-center hidden">
          <button id="load-more" class="px-8 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-xl transition-colors shadow-sm">
            Load More
          </button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ tutorials, baseUrl: import.meta.env.BASE_URL }}>
  // ── Data ──
  const allTutorials = tutorials;
  const PAGE_SIZE = 30;
  let currentPage = 1;
  let filtered = [...allTutorials];
  let viewMode = 'grid';

  // ── Language colors ──
  const langColors = {
    'Python':'#3776AB','JavaScript':'#F7DF1E','TypeScript':'#3178C6',
    'C':'#A8B9CC','C++':'#00599C','Go':'#00ADD8','Rust':'#DEA584',
    'Java':'#007396','Ruby':'#CC342D','Node.js':'#339933','C#':'#239120',
    'Haskell':'#5D4F85','Nim':'#FFE953','PHP':'#777BB4','Swift':'#F05138',
    'Kotlin':'#7F52FF'
  };
  const diffColors = {
    beginner: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
    intermediate: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
    advanced: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
  };
  const typeIcons = {
    article: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
    video: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    repository: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>'
  };

  // ── DOM refs ──
  const searchInput = document.getElementById('search-input');
  const filterCat = document.getElementById('filter-category');
  const filterLang = document.getElementById('filter-language');
  const filterDiff = document.getElementById('filter-difficulty');
  const filterType = document.getElementById('filter-type');
  const clearBtn = document.getElementById('clear-filters');
  const resultCount = document.getElementById('result-count');
  const resultsGrid = document.getElementById('results-grid');
  const emptyState = document.getElementById('empty-state');
  const loadMoreWrap = document.getElementById('load-more-wrap');
  const loadMoreBtn = document.getElementById('load-more');
  const viewGridBtn = document.getElementById('view-grid');
  const viewListBtn = document.getElementById('view-list');
  const slashHint = document.getElementById('slash-hint');

  // ── "/" keyboard shortcut ──
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== searchInput &&
        !['INPUT','TEXTAREA','SELECT'].includes(document.activeElement.tagName)) {
      e.preventDefault();
      searchInput.focus();
      if (slashHint) slashHint.style.display = 'none';
    }
    if (e.key === 'Escape' && document.activeElement === searchInput) {
      searchInput.blur();
      if (slashHint) slashHint.style.display = '';
    }
  });

  searchInput.addEventListener('focus', () => { if (slashHint) slashHint.style.display = 'none'; });
  searchInput.addEventListener('blur', () => { if (slashHint && !searchInput.value) slashHint.style.display = ''; });

  // ── Render card ──
  function renderCard(t) {
    const langs = t.languages.slice(0, 3).map(l =>
      `<span class="inline-flex items-center gap-1 text-xs text-gray-700 dark:text-gray-300"><span class="w-2 h-2 rounded-full flex-shrink-0" style="background:${langColors[l]||'#6366F1'}"></span>${l}</span>`
    ).join('') + (t.languages.length > 3 ? `<span class="text-xs text-gray-500">+${t.languages.length-3}</span>` : '');

    if (viewMode === 'list') {
      return `<a href="${baseUrl}tutorial/${t.slug}" class="group flex items-center gap-4 p-4 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 hover:shadow-md hover:border-primary-300 dark:hover:border-primary-600 transition-all">
        <div class="flex-grow min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-medium text-primary-600 dark:text-primary-400">${t.category}</span>
            <span class="text-xs px-2 py-0.5 rounded-full ${diffColors[t.difficulty]}">${t.difficulty}</span>
          </div>
          <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors truncate">${t.title}</h3>
          <div class="flex items-center gap-3 mt-1.5">${langs}</div>
        </div>
        <div class="flex-shrink-0 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
          ${typeIcons[t.contentType]||''}<span>${t.sourcePlatform}</span>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>`;
    }

    return `<article class="group bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
      <a href="${baseUrl}tutorial/${t.slug}" class="block p-5 h-full flex flex-col">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 px-2 py-1 rounded-full">${t.category}</span>
          <span class="text-xs font-medium px-2 py-1 rounded-full ${diffColors[t.difficulty]}">${t.difficulty}</span>
        </div>
        <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors flex-grow">${t.title}</h3>
        <div class="flex items-center gap-2 flex-wrap mb-3">${langs}</div>
        <div class="flex items-center justify-between pt-3 border-t border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
            ${typeIcons[t.contentType]||''}<span>${t.sourcePlatform}</span>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
    </article>`;
  }

  // ── Filter + Render ──
  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    const cat = filterCat.value;
    const lang = filterLang.value;
    const diff = filterDiff.value;
    const type = filterType.value;

    filtered = allTutorials.filter(t => {
      if (q && !(t.title.toLowerCase().includes(q) || t.category.toLowerCase().includes(q) || t.languages.some(l => l.toLowerCase().includes(q)))) return false;
      if (cat && t.categorySlug !== cat) return false;
      if (lang && !t.languageSlugs.includes(lang)) return false;
      if (diff && t.difficulty !== diff) return false;
      if (type && t.contentType !== type) return false;
      return true;
    });

    currentPage = 1;
    render();

    const hasFilters = q || cat || lang || diff || type;
    clearBtn.classList.toggle('hidden', !hasFilters);
  }

  function render() {
    const visible = filtered.slice(0, currentPage * PAGE_SIZE);
    const hasMore = visible.length < filtered.length;

    if (viewMode === 'list') {
      resultsGrid.className = 'flex flex-col gap-3';
    } else {
      resultsGrid.className = 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5';
    }

    resultsGrid.innerHTML = visible.map(renderCard).join('');
    emptyState.classList.toggle('hidden', filtered.length > 0);
    resultsGrid.classList.toggle('hidden', filtered.length === 0);
    loadMoreWrap.classList.toggle('hidden', !hasMore);

    resultCount.innerHTML = `Showing <span class="font-semibold text-gray-900 dark:text-white">${visible.length}</span> of <span class="font-semibold text-gray-900 dark:text-white">${filtered.length}</span> tutorials`;
  }

  // ── Events ──
  let debounceTimer;
  searchInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(applyFilters, 150);
  });
  filterCat.addEventListener('change', applyFilters);
  filterLang.addEventListener('change', applyFilters);
  filterDiff.addEventListener('change', applyFilters);
  filterType.addEventListener('change', applyFilters);

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    filterCat.value = '';
    filterLang.value = '';
    filterDiff.value = '';
    filterType.value = '';
    applyFilters();
  });

  loadMoreBtn.addEventListener('click', () => {
    currentPage++;
    render();
  });

  viewGridBtn.addEventListener('click', () => {
    viewMode = 'grid';
    viewGridBtn.className = 'p-2 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400';
    viewListBtn.className = 'p-2 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800';
    render();
  });
  viewListBtn.addEventListener('click', () => {
    viewMode = 'list';
    viewListBtn.className = 'p-2 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400';
    viewGridBtn.className = 'p-2 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800';
    render();
  });

  // ── URL params ──
  const params = new URLSearchParams(window.location.search);
  if (params.get('q')) searchInput.value = params.get('q');
  if (params.get('category')) filterCat.value = params.get('category');
  if (params.get('language')) filterLang.value = params.get('language');

  // ── Initial render ──
  applyFilters();
</script>
