---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/navigation/Header.astro';
import Footer from '../../components/navigation/Footer.astro';
import TutorialCard from '../../components/content/TutorialCard.astro';
import { getAllLanguages, getTutorialsByLanguage } from '../../lib/data/collections';

export async function getStaticPaths() {
  const languages = await getAllLanguages();
  return languages.map(language => ({
    params: { slug: language.slug },
    props: { language }
  }));
}

const { language } = Astro.props;
const tutorials = await getTutorialsByLanguage(language.slug);
---

<BaseLayout 
  title={`${language.name} Tutorials - Build Your Own X`}
  description={`${language.tutorialCount}+ tutorials in ${language.name}. Learn by recreating popular technologies from scratch in ${language.name}.`}
>
  <Header />
  
  <main class="flex-grow">
    <!-- Breadcrumb -->
    <div class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex items-center gap-2 text-sm">
          <a href={`${import.meta.env.BASE_URL}`} class="text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">Home</a>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-gray-900 dark:text-white font-medium">{language.name}</span>
        </nav>
      </div>
    </div>
    
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary-50 to-white dark:from-gray-900 dark:to-gray-900/50 py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 mb-4">
          <span 
            class="w-16 h-16 rounded-xl flex items-center justify-center text-white text-2xl font-bold"
            style={`background-color: ${language.brandColor}`}
          >
            {language.name.slice(0, 2)}
          </span>
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">
              {language.name}
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-1">
              {language.tutorialCount} tutorials
            </p>
          </div>
        </div>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl">
          Browse tutorials written in {language.name}. Learn how to build databases, 
          games, web servers, and more using {language.name}.
        </p>
      </div>
    </section>
    
    <!-- Tutorials Grid -->
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {tutorials.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {tutorials.map(tutorial => (
              <TutorialCard tutorial={tutorial} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-gray-500 dark:text-gray-400">No tutorials found for this language.</p>
          </div>
        )}
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>
